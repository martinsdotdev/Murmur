; Code style for Murmur (WinUI 3 / .NET 10).
; Drives `dotnet format`, the compiler's IDE0xxx rules, Visual Studio, Rider, and VS Code.
; Conventions match existing code; see .github/instructions/code-quality.instructions.md.

root = true

; ---- Universal --------------------------------------------------------------

[*]
indent_style = space
end_of_line = crlf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[*.{cs,csproj,xaml,xml,resx,manifest,appxmanifest,pubxml}]
indent_size = 4

[*.{json,yml,yaml,md,toml,ps1,psm1}]
indent_size = 2

; XAML files in the WinUI generated/intermediate trees should not be linted.
[**/{bin,obj}/**]
generated_code = true

; ---- C# ---------------------------------------------------------------------

[*.cs]

; .NET formatting
dotnet_sort_system_directives_first = true
dotnet_separate_import_directive_groups = false

; `this.` qualification, never used in this codebase
dotnet_style_qualification_for_field    = false:warning
dotnet_style_qualification_for_property = false:warning
dotnet_style_qualification_for_method   = false:warning
dotnet_style_qualification_for_event    = false:warning

; Modern language preferences
dotnet_style_predefined_type_for_locals_parameters_members = true:silent
dotnet_style_predefined_type_for_member_access             = true:silent
dotnet_style_object_initializer       = true:suggestion
dotnet_style_collection_initializer   = true:suggestion
dotnet_style_prefer_auto_properties   = true:suggestion
dotnet_style_null_propagation         = true:suggestion
dotnet_style_coalesce_expression      = true:suggestion
dotnet_style_readonly_field           = true:suggestion

; C#-specific
csharp_style_namespace_declarations  = file_scoped:warning
csharp_using_directive_placement     = outside_namespace:warning
csharp_prefer_braces                 = when_multiline:silent
csharp_prefer_simple_using_statement = true:suggestion

csharp_style_var_for_built_in_types    = false:silent
csharp_style_var_when_type_is_apparent = true:suggestion
csharp_style_var_elsewhere             = true:silent

csharp_style_expression_bodied_methods      = when_on_single_line:silent
csharp_style_expression_bodied_properties   = when_on_single_line:silent
csharp_style_expression_bodied_accessors    = when_on_single_line:silent
csharp_style_expression_bodied_lambdas      = when_on_single_line:silent
csharp_style_expression_bodied_constructors = false:silent

csharp_style_pattern_matching_over_is_with_cast_check = true:suggestion
csharp_style_pattern_matching_over_as_with_null_check = true:suggestion
csharp_style_inlined_variable_declaration             = true:suggestion
csharp_style_throw_expression                         = true:suggestion
csharp_style_conditional_delegate_call                = true:suggestion

; Allman braces and switch indent
csharp_new_line_before_open_brace = all
csharp_new_line_before_else      = true
csharp_new_line_before_catch     = true
csharp_new_line_before_finally   = true
csharp_indent_case_contents      = true
csharp_indent_switch_labels      = true

; Spacing
csharp_space_around_binary_operators = before_and_after
csharp_space_after_cast              = false
csharp_space_after_keywords_in_control_flow_statements = true

; ---- Naming -----------------------------------------------------------------
; Project conventions:
;   private/internal instance fields  -> _camelCase
;   private static readonly fields    -> s_camelCase  (e.g. AppState.s_jsonOptions)
;   constants                         -> PascalCase   (suggestion only, Win32 P/Invoke
;                                                      uses SCREAMING_CASE in PowerService)

dotnet_naming_rule.private_instance_fields_underscore.severity = warning
dotnet_naming_rule.private_instance_fields_underscore.symbols  = private_instance_fields
dotnet_naming_rule.private_instance_fields_underscore.style    = underscore_camel
dotnet_naming_symbols.private_instance_fields.applicable_kinds = field
dotnet_naming_symbols.private_instance_fields.applicable_accessibilities = private, internal, private_protected
dotnet_naming_style.underscore_camel.required_prefix = _
dotnet_naming_style.underscore_camel.capitalization  = camel_case

dotnet_naming_rule.private_static_readonly_s_prefix.severity = warning
dotnet_naming_rule.private_static_readonly_s_prefix.symbols  = private_static_readonly_fields
dotnet_naming_rule.private_static_readonly_s_prefix.style    = s_camel
dotnet_naming_symbols.private_static_readonly_fields.applicable_kinds = field
dotnet_naming_symbols.private_static_readonly_fields.applicable_accessibilities = private, internal
dotnet_naming_symbols.private_static_readonly_fields.required_modifiers = static, readonly
dotnet_naming_style.s_camel.required_prefix = s_
dotnet_naming_style.s_camel.capitalization  = camel_case

dotnet_naming_rule.constants_pascal.severity = suggestion
dotnet_naming_rule.constants_pascal.symbols  = constants
dotnet_naming_rule.constants_pascal.style    = pascal
dotnet_naming_symbols.constants.applicable_kinds = field
dotnet_naming_symbols.constants.required_modifiers = const
dotnet_naming_symbols.constants.applicable_accessibilities = *
dotnet_naming_style.pascal.capitalization = pascal_case

; ---- StyleCop rules that conflict with project conventions ------------------

; SA1101, prefix local calls with this.    [project never uses this.]
dotnet_diagnostic.SA1101.severity = none
; SA1309, fields should not begin with _   [_camelCase is intentional]
dotnet_diagnostic.SA1309.severity = none
; SA1633, file must have a header           [no headers in this project]
dotnet_diagnostic.SA1633.severity = none
; SA1503, braces must not be omitted        [single-line `if (x) return;` is heavily used]
dotnet_diagnostic.SA1503.severity = none
; SA1502, element must not be on a single line
dotnet_diagnostic.SA1502.severity = none
; SA1413, use trailing commas in multi-line initializers
dotnet_diagnostic.SA1413.severity = silent
; SA1402, file may only contain a single type
;          [IMemoryBufferByteAccess intentionally co-lives with AudioGraphMixerService]
dotnet_diagnostic.SA1402.severity = none

; Documentation rules, keep XML-doc encouraged but not mandatory
dotnet_diagnostic.SA1600.severity = none   ; elements should be documented
dotnet_diagnostic.SA1601.severity = none   ; partial elements should be documented
dotnet_diagnostic.SA1602.severity = none   ; enum items should be documented
dotnet_diagnostic.SA1611.severity = none   ; parameters should be documented
dotnet_diagnostic.SA1615.severity = none   ; return values should be documented
dotnet_diagnostic.SA1618.severity = none   ; generic type parameters should be documented
dotnet_diagnostic.SA1623.severity = silent ; property doc summary text
dotnet_diagnostic.SA1629.severity = silent ; documentation should end with a period

; ---- CA rules tuned for this codebase ---------------------------------------

; CA1031, do not catch general exception types
;          [used intentionally at "best effort" sites: DiagnosticLog, AppState save,
;           shutdown paths in MainWindow.OnWindowClosed / QuitApp]
dotnet_diagnostic.CA1031.severity = suggestion
; CA1303, do not pass literals as localized parameters [Murmur is English-only today]
dotnet_diagnostic.CA1303.severity = none
; CA1062, validate args of public methods
;          [internal app, not a library; nullable-annotated parameters carry the contract]
dotnet_diagnostic.CA1062.severity = suggestion

; ---- Generated / designer code ----------------------------------------------

[*.{g.cs,g.i.cs,Designer.cs,AssemblyInfo.cs,GlobalUsings.g.cs}]
generated_code = true
dotnet_analyzer_diagnostic.severity = none
