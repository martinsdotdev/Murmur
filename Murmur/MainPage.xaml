<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Murmur.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:Murmur"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewmodels="using:Murmur.ViewModels"
    xmlns:views="using:Murmur.Views"
    SizeChanged="Page_SizeChanged"
    mc:Ignorable="d">

    <Grid>
        <Grid x:Name="ContentRoot" HorizontalAlignment="Center">
            <ScrollViewer
                HorizontalScrollMode="Disabled"
                Padding="0,12,0,0"
                VerticalScrollBarVisibility="Auto"
                VerticalScrollMode="Enabled">
                <StackPanel Padding="16,0,16,12">
                    <ItemsRepeater
                        ItemsSource="{x:Bind ViewModel.SoundCards, Mode=OneWay}"
                        Visibility="{x:Bind ViewModel.IsListView, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                        <ItemsRepeater.Layout>
                            <StackLayout Spacing="4" />
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate x:DataType="viewmodels:SoundCardViewModel">
                                <views:SoundCardControl ViewModel="{x:Bind}" />
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>

                    <ItemsRepeater
                        ItemsSource="{x:Bind ViewModel.SoundCards, Mode=OneWay}"
                        Visibility="{x:Bind ViewModel.IsGridView, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                        <ItemsRepeater.Layout>
                            <UniformGridLayout
                                ItemsStretch="Fill"
                                MinColumnSpacing="8"
                                MinItemHeight="140"
                                MinItemWidth="160"
                                MinRowSpacing="8" />
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate x:DataType="viewmodels:SoundCardViewModel">
                                <views:SoundTileControl ViewModel="{x:Bind}" />
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>

                    <!--  CornerRadius=4 because this is an in-page button (8 is reserved for top-level/overlay surfaces).  -->
                    <Button
                        x:Name="AddSoundButton"
                        Margin="0,12,0,0"
                        Padding="12,8,12,8"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Center"
                        AutomationProperties.AutomationId="AddSoundButton"
                        AutomationProperties.Name="Add a sound"
                        Background="Transparent"
                        BorderBrush="Transparent"
                        BorderThickness="1"
                        CornerRadius="4"
                        IsEnabled="{x:Bind ViewModel.IsReady, Mode=OneWay}">
                        <Button.Flyout>
                            <MenuFlyout Placement="Top">
                                <MenuFlyoutItem
                                    AutomationProperties.AutomationId="AddFromFileMenuItem"
                                    Click="AddFromFile_Click"
                                    Text="From file…">
                                    <MenuFlyoutItem.Icon>
                                        <FontIcon Glyph="&#xE8E5;" />
                                    </MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                                <MenuFlyoutItem
                                    AutomationProperties.AutomationId="AddFromUrlMenuItem"
                                    Click="AddFromUrl_Click"
                                    Text="From URL…">
                                    <MenuFlyoutItem.Icon>
                                        <FontIcon Glyph="&#xE71B;" />
                                    </MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                            </MenuFlyout>
                        </Button.Flyout>
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <FontIcon
                                VerticalAlignment="Center"
                                FontSize="13"
                                Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                Glyph="&#xE710;" />
                            <TextBlock
                                VerticalAlignment="Center"
                                Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                Style="{StaticResource BodyTextBlockStyle}"
                                Text="Add a sound" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</Page>
