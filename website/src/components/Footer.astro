---
import { sounds } from '../data/sounds.ts';
import BrandLogo from './BrandLogo.astro';
import { repoUrl, releasesUrl, issuesUrl, blanketUrl } from '../data/site.ts';

const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container footer-grid">
    <div class="footer-brand">
      <a href="#" class="footer-mark" aria-label="Murmur">
        <BrandLogo size={40} />
        <span>murmur<span class="dot">.</span></span>
      </a>
      <p>An ambient sound mixer for Windows. Born from <a href={blanketUrl} rel="noopener" target="_blank">Blanket</a>.</p>
    </div>

    <nav class="footer-links" aria-label="Footer">
      <h3 class="footer-h">Project</h3>
      <ul>
        <li><a href={repoUrl} target="_blank" rel="noopener">Source on GitHub</a></li>
        <li><a href={issuesUrl} target="_blank" rel="noopener">Report a bug</a></li>
        <li><a href={releasesUrl} target="_blank" rel="noopener">Releases</a></li>
        <li><a href={`${repoUrl}/blob/master/Murmur/Sounds/SOUNDS_LICENSING.md`} target="_blank" rel="noopener">Sound licenses</a></li>
      </ul>
    </nav>

    <nav class="footer-links" aria-label="Credits">
      <h3 class="footer-h">Credits</h3>
      <ul>
        <li>Original GTK app: <a href={blanketUrl} target="_blank" rel="noopener">Blanket</a> by Rafael Mardojai CM</li>
        <li>Soundscape edits by Porrumentzio</li>
        <li>Icons from <a href="https://lucide.dev" target="_blank" rel="noopener">lucide.dev</a></li>
        <li>Type by <a href="https://fonts.google.com/specimen/Fraunces" target="_blank" rel="noopener">Fraunces</a> / <a href="https://fonts.google.com/specimen/Manrope" target="_blank" rel="noopener">Manrope</a></li>
      </ul>
    </nav>
  </div>

  <details class="attribution-block container">
    <summary>
      <span class="footer-h">Sound attributions</span>
      <span class="mono">CC0 · CC BY · CC BY-SA · Public Domain</span>
    </summary>
    <table class="attribution-table">
      <thead>
        <tr><th>Sound</th><th>Author</th><th>License</th></tr>
      </thead>
      <tbody>
        {sounds.map((s) => (
          <tr>
            <td>{s.name}</td>
            <td>
              <a href={s.attribution.sourceUrl} target="_blank" rel="noopener">
                {s.attribution.author}
              </a>
            </td>
            <td><span class="lic-pill mono">{s.attribution.license}</span></td>
          </tr>
        ))}
      </tbody>
    </table>
  </details>

  <div class="footer-base container">
    <div>© {year} Murmur — released under the <a href={`${repoUrl}/blob/master/LICENSE`} target="_blank" rel="noopener">GPLv3</a>.</div>
    <div class="mono">Built with Astro · Hosted on GitHub Pages</div>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--hairline);
    padding-top: var(--sp-8);
    padding-bottom: var(--sp-6);
    margin-top: var(--sp-9);
    background: var(--bg-elevated);
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr 1fr;
    gap: var(--sp-7);
    margin-bottom: var(--sp-7);
  }

  @media (max-width: 720px) {
    .footer-grid { grid-template-columns: 1fr; gap: var(--sp-5); }
  }

  .footer-brand {
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
  }

  .footer-mark {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-3);
    color: var(--text-primary);
    font-family: 'Fraunces Variable', serif;
    font-variation-settings: 'opsz' 36, 'SOFT' 100;
    font-weight: 500;
    font-size: var(--fs-xl);
    letter-spacing: -0.02em;
  }
  .footer-mark .dot { color: var(--accent); }

  .footer-brand p {
    color: var(--text-secondary);
    font-size: var(--fs-sm);
    max-width: 30ch;
  }

  .footer-h {
    font-family: 'IBM Plex Mono', monospace;
    font-size: var(--fs-xs);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--text-tertiary);
    font-weight: 500;
    margin-bottom: var(--sp-3);
  }

  .footer-links ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
  }

  .footer-links a {
    color: var(--text-secondary);
    font-size: var(--fs-sm);
  }
  .footer-links a:hover { color: var(--text-primary); }
  .footer-links li { color: var(--text-secondary); font-size: var(--fs-sm); }

  .attribution-block {
    border-top: 1px dashed var(--hairline);
    border-bottom: 1px dashed var(--hairline);
    padding-block: var(--sp-4);
    margin-bottom: var(--sp-5);
  }

  .attribution-block summary {
    display: flex;
    justify-content: space-between;
    align-items: center;
    cursor: pointer;
    list-style: none;
    color: var(--text-secondary);
    gap: var(--sp-4);
  }
  .attribution-block summary::-webkit-details-marker { display: none; }
  .attribution-block summary:hover { color: var(--text-primary); }
  .attribution-block summary .footer-h { margin: 0; }
  .attribution-block summary .mono {
    color: var(--text-tertiary);
    font-size: var(--fs-xs);
    letter-spacing: 0.1em;
  }

  .attribution-table {
    width: 100%;
    margin-top: var(--sp-4);
    border-collapse: collapse;
    font-size: var(--fs-sm);
  }

  .attribution-table th,
  .attribution-table td {
    padding: var(--sp-2) var(--sp-3);
    text-align: left;
    border-bottom: 1px solid var(--hairline);
  }

  .attribution-table th {
    color: var(--text-tertiary);
    font-weight: 500;
    font-size: var(--fs-xs);
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .attribution-table td { color: var(--text-secondary); }
  .attribution-table a { color: var(--text-primary); text-decoration: underline; text-decoration-color: var(--hairline-strong); text-underline-offset: 3px; }

  .lic-pill {
    display: inline-block;
    padding: 2px var(--sp-2);
    background: var(--bg-card);
    border: 1px solid var(--hairline);
    border-radius: 999px;
    color: var(--text-tertiary);
    font-size: var(--fs-xs);
  }

  .footer-base {
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: var(--sp-3);
    color: var(--text-tertiary);
    font-size: var(--fs-xs);
  }
  .footer-base a { color: var(--text-secondary); text-decoration: underline; text-decoration-color: var(--hairline-strong); }
  .footer-base a:hover { color: var(--text-primary); }
</style>
