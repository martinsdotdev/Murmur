---
import { features } from '../data/features.ts';
import { sounds } from '../data/sounds.ts';
import SoundIcon from './SoundIcon.astro';

const [wide, ...rest] = features;
---

<section class="features" id="features" aria-labelledby="features-heading">
  <div class="container">
    <header class="features-header">
      <span class="eyebrow">What's inside</span>
      <h2 id="features-heading">Small app. Surprisingly thorough.</h2>
    </header>

    <div class="features-grid">
      <article class="card card-wide">
        <div class="card-body">
          <span class="card-tag mono">14 soundscapes</span>
          <h3>{wide.title}</h3>
          <p>{wide.body}</p>
        </div>
        <div class="sound-chips" aria-hidden="true">
          {sounds.map((s) => (
            <span class={`chip chip--${s.category}`}>
              <SoundIcon path={s.iconPath} size={14} strokeWidth={1.5} />
              {s.name}
            </span>
          ))}
        </div>
      </article>

      {rest.map((f) => (
        <article class="card">
          <div class="card-icon">
            <SoundIcon path={f.iconPath} size={22} />
          </div>
          <h3>{f.title}</h3>
          <p>{f.body}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .features {
    position: relative;
  }

  .features-header {
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
    margin-bottom: var(--sp-7);
    max-width: 32ch;
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: var(--sp-4);
  }

  .card {
    grid-column: span 2;
    background: var(--bg-card);
    border: 1px solid var(--hairline);
    border-radius: var(--r-lg);
    padding: var(--sp-6);
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
    position: relative;
    overflow: hidden;
    transition: border-color var(--dur-med) var(--ease-out),
      transform var(--dur-med) var(--ease-out),
      box-shadow var(--dur-med) var(--ease-out);
  }

  .card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(
      350px circle at var(--mx, 50%) var(--my, 0%),
      rgba(245, 195, 117, 0.08),
      transparent 60%
    );
    opacity: 0;
    transition: opacity var(--dur-med) var(--ease-out);
    pointer-events: none;
  }

  .card:hover {
    border-color: var(--hairline-strong);
    transform: translateY(-2px);
    box-shadow: 0 24px 60px -32px rgba(0, 0, 0, 0.6);
  }

  .card:hover::before {
    opacity: 1;
  }

  .card-wide {
    grid-column: span 6;
    flex-direction: row;
    align-items: stretch;
    gap: var(--sp-7);
    padding: var(--sp-7);
  }

  .card-wide .card-body {
    flex: 0 0 38%;
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
  }

  .card-tag {
    align-self: flex-start;
    padding: var(--sp-1) var(--sp-3);
    border-radius: 999px;
    background: var(--bg-card-active);
    color: var(--accent-hover);
    font-size: var(--fs-xs);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    border: 1px solid var(--hairline-strong);
  }

  .sound-chips {
    flex: 1;
    display: flex;
    flex-wrap: wrap;
    align-content: flex-start;
    gap: var(--sp-2);
  }

  .chip {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
    padding: var(--sp-2) var(--sp-3);
    border-radius: 999px;
    background: var(--bg-elevated);
    border: 1px solid var(--hairline);
    color: var(--text-secondary);
    font-size: var(--fs-sm);
    transition: color var(--dur-fast) var(--ease-out),
      background var(--dur-fast) var(--ease-out),
      transform var(--dur-fast) var(--ease-out);
  }

  .chip:hover {
    color: var(--text-primary);
    transform: translateY(-1px);
  }

  .chip--nature   { color: #cbd6a4; }
  .chip--urban    { color: var(--accent-hover); }
  .chip--generated { color: #b9a4d6; }

  .card .card-icon {
    width: 44px;
    height: 44px;
    border-radius: var(--r-md);
    display: grid;
    place-items: center;
    background: var(--bg-card-active);
    color: var(--accent);
    border: 1px solid var(--hairline-strong);
  }

  .card h3 {
    font-size: var(--fs-xl);
    font-weight: 500;
  }

  .card p {
    color: var(--text-secondary);
    font-size: var(--fs-body);
  }

  /* Tablet: rebalance the grid (2 cols, wide spans both) */
  @media (max-width: 980px) {
    .features-grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .card { grid-column: span 1; }
    .card-wide { grid-column: span 2; flex-direction: column; }
    .card-wide .card-body { flex: none; }
  }

  /* Phone: 1 col stack */
  @media (max-width: 600px) {
    .features-grid { grid-template-columns: 1fr; }
    .card,
    .card-wide { grid-column: span 1; padding: var(--sp-5); }
  }
</style>

<script>
  // Per-card cursor-tracked glow — small flourish, no library
  const cards = document.querySelectorAll<HTMLElement>('.card');
  cards.forEach((card) => {
    card.addEventListener('pointermove', (e) => {
      const r = card.getBoundingClientRect();
      card.style.setProperty('--mx', `${e.clientX - r.left}px`);
      card.style.setProperty('--my', `${e.clientY - r.top}px`);
    });
  });
</script>
