---
/**
 * Two-state theme toggle. Reads/writes localStorage('theme') and sets
 * data-theme on <html>. The bootstrap script in BaseLayout runs before
 * paint so there's no flash of wrong theme.
 */
---

<button
  type="button"
  id="theme-toggle"
  class="theme-toggle"
  aria-label="Toggle color theme"
  title="Toggle color theme"
>
  <svg class="sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <circle cx="12" cy="12" r="4"></circle>
    <path d="M12 2v2 M12 20v2 M4.93 4.93l1.41 1.41 M17.66 17.66l1.41 1.41 M2 12h2 M20 12h2 M6.34 17.66l-1.41 1.41 M19.07 4.93l-1.41 1.41"></path>
  </svg>
  <svg class="moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"></path>
  </svg>
</button>

<style>
  .theme-toggle {
    width: 36px;
    height: 36px;
    border-radius: 999px;
    display: inline-grid;
    place-items: center;
    color: var(--text-secondary);
    transition: background var(--dur-fast) var(--ease-out),
      color var(--dur-fast) var(--ease-out);
    position: relative;
  }
  .theme-toggle:hover {
    background: var(--bg-card);
    color: var(--text-primary);
  }
  .theme-toggle svg {
    width: 18px;
    height: 18px;
    grid-area: 1 / 1;
    transition: opacity var(--dur-fast) var(--ease-out),
      transform var(--dur-med) var(--ease-out);
  }
  :root[data-theme='light'] .theme-toggle .sun,
  :root:not([data-theme='light']) .theme-toggle .moon {
    opacity: 0;
    transform: scale(0.6) rotate(-30deg);
  }
  :root[data-theme='light'] .theme-toggle .moon,
  :root:not([data-theme='light']) .theme-toggle .sun {
    opacity: 1;
    transform: scale(1) rotate(0deg);
  }
</style>

<script>
  const btn = document.getElementById('theme-toggle');
  btn?.addEventListener('click', () => {
    const next = document.documentElement.dataset.theme === 'light' ? 'dark' : 'light';
    document.documentElement.dataset.theme = next;
    try {
      localStorage.setItem('theme', next);
    } catch {
      /* private browsing — no-op */
    }
  });
</script>
