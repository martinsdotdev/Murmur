---
/**
 * Download section. Tries to fetch the latest GitHub release at build time so
 * the version + asset URLs are baked into the static HTML. Falls back to
 * "no release yet" copy when none exists.
 */
import { repoUrl, releasesUrl, latestReleaseApi } from '../data/site.ts';

interface ReleaseAsset {
  name: string;
  browser_download_url: string;
  size: number;
}
interface Release {
  tag_name: string;
  name: string;
  published_at: string;
  html_url: string;
  assets: ReleaseAsset[];
}

let release: Release | null = null;
try {
  const res = await fetch(latestReleaseApi, {
    headers: { Accept: 'application/vnd.github+json' },
  });
  if (res.ok) release = (await res.json()) as Release;
} catch {
  // Offline build / API rate limited, fall through to placeholder.
}

const x64 = release?.assets.find((a) => /-x64\.msixbundle$/i.test(a.name));
const arm64 = release?.assets.find((a) => /-arm64\.msixbundle$/i.test(a.name));
const cer = release?.assets.find((a) => /\.cer$/i.test(a.name));
const version = release?.tag_name?.replace(/^v/, '') ?? null;

function fmtSize(bytes?: number): string {
  if (!bytes) return '';
  return `${(bytes / 1024 / 1024).toFixed(1)} MB`;
}
---

<section class="download" id="download" aria-labelledby="download-heading">
  <div class="container download-grid">
    <div class="download-pitch">
      <h2 id="download-heading" class="fluent-largetitle">
        {version
          ? <>Get the app <span class="version-tag fluent-mono">v{version}</span></>
          : 'Get the app'}
      </h2>

      <dl class="reqs">
        <div class="req-row">
          <dt class="fluent-caption1-strong">OS</dt>
          <dd class="fluent-body1">Windows 10 v19041+ or Windows 11</dd>
        </div>
        <div class="req-row">
          <dt class="fluent-caption1-strong">Arch</dt>
          <dd class="fluent-body1">x64 · ARM64</dd>
        </div>
        <div class="req-row">
          <dt class="fluent-caption1-strong">License</dt>
          <dd class="fluent-body1">GPLv3</dd>
        </div>
      </dl>
    </div>

    <div class="download-card">
      {version ? (
        <>
          <a
            class="btn btn-primary btn-large download-primary"
            href={x64?.browser_download_url ?? releasesUrl}
            download={x64?.name}
          >
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18" aria-hidden="true">
              <path d="M12 17V3 M6 11l6 6 6-6 M19 21H5"></path>
            </svg>
            Download for Windows
            <span class="download-meta fluent-mono">{fmtSize(x64?.size)}</span>
          </a>

          <div class="download-alt">
            {arm64 && (
              <a class="alt-btn" href={arm64.browser_download_url} download={arm64.name}>
                <span class="fluent-body1-strong">ARM64 build</span>
                <span class="fluent-caption1 alt-size">{fmtSize(arm64.size)}</span>
              </a>
            )}
            {cer && (
              <a class="alt-btn" href={cer.browser_download_url} download={cer.name}>
                <span class="fluent-body1-strong">Trust certificate</span>
                <span class="fluent-caption1 alt-size">.cer</span>
              </a>
            )}
            <a class="alt-btn" href={releasesUrl} target="_blank" rel="noopener">
              <span class="fluent-body1-strong">All releases</span>
              <span class="fluent-caption1 alt-size">→</span>
            </a>
          </div>

          <details class="trust-disclosure">
            <summary>
              <span class="fluent-body1-strong">Why trust a certificate?</span>
              <svg class="chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="14" height="14" aria-hidden="true">
                <path d="m6 9 6 6 6-6"></path>
              </svg>
            </summary>
            <ol class="trust-steps">
              <li>
                <span class="step fluent-caption1-strong">01</span>
                <div>
                  <strong class="fluent-body1-strong">Download the certificate</strong>
                  <p class="fluent-body1">The <span class="fluent-mono">.cer</span> file is shipped with each release. Download once per release.</p>
                </div>
              </li>
              <li>
                <span class="step fluent-caption1-strong">02</span>
                <div>
                  <strong class="fluent-body1-strong">Install it</strong>
                  <p class="fluent-body1">Right-click the <span class="fluent-mono">.cer</span> → <em>Install Certificate</em> → <em>Local Machine</em> → place in <em>Trusted People</em>.</p>
                </div>
              </li>
              <li>
                <span class="step fluent-caption1-strong">03</span>
                <div>
                  <strong class="fluent-body1-strong">Run the installer</strong>
                  <p class="fluent-body1">Double-click the <span class="fluent-mono">.msixbundle</span>. Murmur installs from Start menu like any Store app.</p>
                </div>
              </li>
            </ol>
            <p class="trust-note fluent-caption1">
              Self-signing keeps the project free and independent. A future release may move to a CA-signed cert or Microsoft Store
              submission to remove this step.
            </p>
          </details>
        </>
      ) : (
        <>
          <a class="btn btn-primary btn-large download-primary" href={repoUrl} target="_blank" rel="noopener">
            <svg viewBox="0 0 24 24" fill="currentColor" width="18" height="18" aria-hidden="true">
              <path
                d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.1.79-.25.79-.56v-2.16c-3.2.7-3.87-1.37-3.87-1.37-.52-1.32-1.27-1.67-1.27-1.67-1.04-.71.08-.7.08-.7 1.15.08 1.76 1.18 1.76 1.18 1.02 1.75 2.69 1.25 3.34.95.1-.74.4-1.25.73-1.54-2.55-.29-5.24-1.27-5.24-5.65 0-1.25.45-2.27 1.18-3.07-.12-.29-.51-1.46.11-3.04 0 0 .96-.31 3.16 1.17.92-.26 1.9-.39 2.88-.39s1.96.13 2.88.39c2.2-1.48 3.16-1.17 3.16-1.17.62 1.58.23 2.75.11 3.04.74.8 1.18 1.82 1.18 3.07 0 4.39-2.69 5.36-5.25 5.65.41.36.78 1.06.78 2.13v3.16c0 .31.21.67.79.56C20.21 21.39 23.5 17.08 23.5 12 23.5 5.65 18.35.5 12 .5z"
              ></path>
            </svg>
            View source on GitHub
          </a>
          <p class="download-soon fluent-caption1">v1.0.0 build coming soon, watch the repo to be notified.</p>
        </>
      )}
    </div>
  </div>
</section>

<style>
  .download {
    position: relative;
  }

  .download-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-xxxl);
    align-items: start;
  }

  @media (max-width: 880px) {
    .download-grid { grid-template-columns: 1fr; gap: var(--space-l); }
  }

  .download-pitch {
    display: flex;
    flex-direction: column;
    gap: var(--space-m);
  }

  .download-pitch h2 .version-tag {
    color: var(--color-brand-foreground);
    font-size: 0.5em;
    margin-left: var(--space-s);
    padding: var(--space-xxs) var(--space-s);
    background-color: var(--color-subtle-background-selected);
    border-radius: var(--border-radius-small);
    border: var(--stroke-width-thin) solid var(--color-brand-stroke-2);
    vertical-align: middle;
    font-weight: var(--font-weight-semibold);
    line-height: 1.4;
  }

  .download-blurb {
    color: var(--color-neutral-foreground-2);
    font-weight: var(--font-weight-regular);
  }

  /* Fluent 2 List pattern: rows separated by hairlines, label/value grid */
  .reqs {
    margin-top: var(--space-l);
    border-top: var(--stroke-width-thin) solid var(--color-neutral-stroke-2);
  }

  .req-row {
    display: grid;
    grid-template-columns: 80px 1fr;
    gap: var(--space-mn);
    padding-block: var(--space-m);
    border-bottom: var(--stroke-width-thin) solid var(--color-neutral-stroke-2);
  }

  .req-row dt {
    color: var(--color-neutral-foreground-3);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .req-row dd {
    color: var(--color-neutral-foreground-1);
    margin: 0;
  }

  /* Fluent 2 elevated card, layer3 background, $shadow16 elevation */
  .download-card {
    background-color: var(--color-neutral-background-2);
    border: var(--stroke-width-thin) solid var(--color-neutral-stroke-1);
    border-radius: var(--border-radius-large);
    padding: var(--space-xl);
    display: flex;
    flex-direction: column;
    gap: var(--space-mn);
    box-shadow: var(--shadow-16);
  }

  .download-primary {
    width: 100%;
    justify-content: center;
  }

  .download-meta {
    margin-left: auto;
    color: var(--color-neutral-foreground-on-brand);
    opacity: 0.75;
  }

  .download-alt {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
    gap: var(--space-s);
  }

  .alt-btn {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-m) var(--space-mn);
    border-radius: var(--border-radius-small);
    background-color: var(--color-neutral-background-1);
    border: var(--stroke-width-thin) solid var(--color-neutral-stroke-1);
    color: var(--color-neutral-foreground-1);
    transition:
      background-color var(--duration-faster) var(--curve-easy-ease),
      border-color var(--duration-faster) var(--curve-easy-ease),
      color var(--duration-faster) var(--curve-easy-ease);
    text-decoration: none;
  }

  .alt-btn:hover {
    background-color: var(--color-neutral-background-3);
    border-color: var(--color-neutral-stroke-accessible);
    color: var(--color-neutral-foreground-1);
    text-decoration: none;
  }

  .alt-size { color: var(--color-neutral-foreground-3); }

  .download-soon {
    color: var(--color-neutral-foreground-3);
    text-align: center;
    padding-block: var(--space-m);
  }

  /* Fluent 2 Expander pattern */
  .trust-disclosure {
    border-top: var(--stroke-width-thin) solid var(--color-neutral-stroke-2);
    padding-top: var(--space-mn);
    margin-top: var(--space-xs);
  }

  .trust-disclosure summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    cursor: pointer;
    list-style: none;
    color: var(--color-neutral-foreground-1);
    padding-block: var(--space-s);
    border-radius: var(--border-radius-small);
    transition: color var(--duration-faster) var(--curve-easy-ease);
  }
  .trust-disclosure summary::-webkit-details-marker { display: none; }
  .trust-disclosure summary:hover .chevron { color: var(--color-neutral-foreground-1); }
  .chevron {
    color: var(--color-neutral-foreground-3);
    transition: transform var(--duration-fast) var(--curve-easy-ease),
                color var(--duration-faster) var(--curve-easy-ease);
  }
  .trust-disclosure[open] .chevron { transform: rotate(180deg); }

  .trust-steps {
    list-style: none;
    margin-top: var(--space-l);
    display: flex;
    flex-direction: column;
    gap: var(--space-mn);
  }

  .trust-steps li {
    display: grid;
    grid-template-columns: 32px 1fr;
    gap: var(--space-m);
    align-items: start;
  }

  .step {
    color: var(--color-brand-foreground);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    line-height: 1.6;
  }

  .trust-steps strong {
    color: var(--color-neutral-foreground-1);
    display: block;
    margin-bottom: var(--space-xxs);
  }

  .trust-steps p {
    color: var(--color-neutral-foreground-2);
    margin: 0;
  }

  .trust-note {
    margin-top: var(--space-mn);
    color: var(--color-neutral-foreground-3);
    line-height: 1.5;
  }
</style>
