---
/**
 * The Tier 3 launch icon, inlined as SVG so it inherits the page's text color
 * for the wordmark and animates the audio bars on hover.
 *
 * SVG body kept verbatim from Murmur/Assets/Source/AppIcon.svg so a redesign
 * to that file requires re-pasting here (intentional: tiny coupling, big payoff
 * in brand cohesion). The audio-bar `<rect>` elements get `class="bar"` for the
 * breathing animation.
 */

interface Props {
  size?: number;
  /** When true, the audio bars do a 3s breathing animation (hero-only). */
  animated?: boolean;
  class?: string;
}

const { size = 56, animated = false, class: className = '' } = Astro.props;
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  viewBox="0 0 768 768"
  width={size}
  height={size}
  class={`brand-logo ${animated ? 'animated' : ''} ${className}`}
  aria-label="Murmur"
  role="img"
>
  <defs>
    <radialGradient id="bl-tile" cx="0.7" cy="0.15" r="0.95">
      <stop offset="0" stop-color="#FFEDC8"></stop>
      <stop offset="0.5" stop-color="#F5C375"></stop>
      <stop offset="1" stop-color="#A85820"></stop>
    </radialGradient>
    <linearGradient id="bl-cup" x1="0" y1="253" x2="0" y2="515" gradientUnits="userSpaceOnUse">
      <stop offset="0%" stop-color="#8B5E3C"></stop>
      <stop offset="100%" stop-color="#21120E"></stop>
    </linearGradient>
    <filter id="bl-cup-shadow" x="-30%" y="-20%" width="160%" height="160%">
      <feGaussianBlur in="SourceAlpha" stdDeviation="22" result="blur-ambient"></feGaussianBlur>
      <feOffset in="blur-ambient" dx="0" dy="16" result="offset-ambient"></feOffset>
      <feComponentTransfer in="offset-ambient" result="ambient">
        <feFuncA type="linear" slope="0.3"></feFuncA>
      </feComponentTransfer>
      <feGaussianBlur in="SourceAlpha" stdDeviation="6" result="blur-key"></feGaussianBlur>
      <feOffset in="blur-key" dx="0" dy="4" result="offset-key"></feOffset>
      <feComponentTransfer in="offset-key" result="key">
        <feFuncA type="linear" slope="0.5"></feFuncA>
      </feComponentTransfer>
      <feMerge>
        <feMergeNode in="ambient"></feMergeNode>
        <feMergeNode in="key"></feMergeNode>
        <feMergeNode in="SourceGraphic"></feMergeNode>
      </feMerge>
    </filter>
  </defs>
  <rect width="768" height="768" rx="144" fill="url(#bl-tile)"></rect>
  <rect class="bar bar-l" x="170" y="125" width="64" height="64" rx="32" fill="white"></rect>
  <rect class="bar bar-c" x="298" y="61" width="64" height="128" rx="32" fill="white"></rect>
  <rect class="bar bar-r" x="426" y="125" width="64" height="64" rx="32" fill="white"></rect>
  <g filter="url(#bl-cup-shadow)">
    <path
      d="M 126 253 C 92 253 64 281 64 315 V 477 a 256 256 0 0 0 509 38 h 24 a 107 107 0 0 0 0 -214 h -22 c -6 -28 -31 -48 -60 -48 H 126 Z M 576 349 h 21 a 59 59 0 1 1 0 118 H 576 V 349 Z"
      fill="url(#bl-cup)"
      fill-rule="evenodd"></path>
  </g>
</svg>

<style>
  .brand-logo {
    display: block;
    border-radius: clamp(8px, 18.75%, 32px);
    transform-origin: center;
  }

  .brand-logo .bar {
    transform-origin: 50% 100%;
    transform-box: fill-box;
  }

  .brand-logo.animated .bar-l {
    animation: bar-pulse 3s ease-in-out infinite;
    animation-delay: -1.4s;
  }
  .brand-logo.animated .bar-c {
    animation: bar-pulse 3s ease-in-out infinite;
    animation-delay: -0.7s;
  }
  .brand-logo.animated .bar-r {
    animation: bar-pulse 3s ease-in-out infinite;
  }

  @keyframes bar-pulse {
    0%,
    100% {
      transform: scaleY(1);
      opacity: 0.95;
    }
    50% {
      transform: scaleY(1.08);
      opacity: 1;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .brand-logo.animated .bar {
      animation: none;
    }
  }
</style>
