---
import BrandLogo from './BrandLogo.astro';
import { repoUrl, blanketUrl } from '../data/site.ts';
---

<section class="hero" aria-labelledby="hero-heading">
  <div class="hero-glow" aria-hidden="true"></div>
  <div class="container hero-stack">
    <div class="hero-mark" aria-hidden="true">
      <BrandLogo size={120} animated={true} />
    </div>

    <span class="eyebrow">Ambient sound mixer · Windows</span>

    <h1 id="hero-heading" class="hero-title">
      Mix the sounds of <em>nature</em>, the <em>city</em>, and soft static into your own ambience.
    </h1>

    <p class="hero-sub">
      An open-source desktop mixer for focus, sleep, and the quiet in&#8209;between. Born from
      <a href={blanketUrl} rel="noopener" target="_blank">Blanket</a>, native to Windows.
    </p>

    <div class="hero-ctas">
      <a href="#download" class="btn btn-primary">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18" aria-hidden="true">
          <path d="M12 17V3 M6 11l6 6 6-6 M19 21H5"></path>
        </svg>
        Download for Windows
      </a>
      <a href={repoUrl} class="btn btn-ghost" target="_blank" rel="noopener">
        <svg viewBox="0 0 24 24" fill="currentColor" width="18" height="18" aria-hidden="true">
          <path
            d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.1.79-.25.79-.56v-2.16c-3.2.7-3.87-1.37-3.87-1.37-.52-1.32-1.27-1.67-1.27-1.67-1.04-.71.08-.7.08-.7 1.15.08 1.76 1.18 1.76 1.18 1.02 1.75 2.69 1.25 3.34.95.1-.74.4-1.25.73-1.54-2.55-.29-5.24-1.27-5.24-5.65 0-1.25.45-2.27 1.18-3.07-.12-.29-.51-1.46.11-3.04 0 0 .96-.31 3.16 1.17.92-.26 1.9-.39 2.88-.39s1.96.13 2.88.39c2.2-1.48 3.16-1.17 3.16-1.17.62 1.58.23 2.75.11 3.04.74.8 1.18 1.82 1.18 3.07 0 4.39-2.69 5.36-5.25 5.65.41.36.78 1.06.78 2.13v3.16c0 .31.21.67.79.56C20.21 21.39 23.5 17.08 23.5 12 23.5 5.65 18.35.5 12 .5z"
          ></path>
        </svg>
        View on GitHub
      </a>
    </div>

    <p class="hero-meta mono">
      <span aria-hidden="true">⌘</span> Free · GPLv3 · No telemetry · No account
    </p>
  </div>
</section>

<style>
  .hero {
    position: relative;
    padding-block: clamp(var(--sp-9), 18vw, 12rem) var(--sp-9);
    overflow: hidden;
    isolation: isolate;
  }

  /* Radial amber bloom behind the mark — the warmth of a candle in a dark room */
  .hero-glow {
    position: absolute;
    top: -10%;
    left: 50%;
    transform: translateX(-50%);
    width: min(900px, 100%);
    aspect-ratio: 1;
    background: radial-gradient(
      circle at 50% 30%,
      rgba(255, 237, 200, 0.22) 0%,
      rgba(245, 195, 117, 0.16) 18%,
      rgba(168, 88, 32, 0.08) 38%,
      transparent 65%
    );
    z-index: -1;
    pointer-events: none;
    filter: blur(8px);
  }

  .hero-stack {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--sp-5);
  }

  .hero-mark {
    /* Float the mark with a slow drift — like steam from a cup */
    animation: drift 10s ease-in-out infinite;
    filter: drop-shadow(0 30px 60px rgba(168, 88, 32, 0.35));
  }

  @keyframes drift {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-8px); }
  }

  .hero-stack > * {
    opacity: 0;
    animation: rise 700ms var(--ease-out) forwards;
  }
  .hero-mark            { animation-delay: 0ms;   animation-duration: 900ms; animation-name: rise, drift; animation-timing-function: var(--ease-out), ease-in-out; animation-iteration-count: 1, infinite; animation-fill-mode: forwards, none; }
  .hero-stack .eyebrow  { animation-delay: 180ms; }
  .hero-title           { animation-delay: 280ms; }
  .hero-sub             { animation-delay: 380ms; }
  .hero-ctas            { animation-delay: 480ms; }
  .hero-meta            { animation-delay: 600ms; }

  @keyframes rise {
    from { opacity: 0; transform: translateY(12px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /*
   * Reduced motion: skip ALL the rise/drift animations and show everything
   * at full opacity immediately. Without these explicit overrides, Safari
   * (and Firefox in some configs) suspend the animations and the hero
   * stays invisible — the original CSS used opacity:0 as the start state.
   */
  @media (prefers-reduced-motion: reduce) {
    .hero-mark, .hero-stack > * {
      animation: none !important;
      opacity: 1;
      transform: none;
    }
  }

  .hero-title {
    max-width: 18ch;
    margin-inline: auto;
    font-variation-settings: 'opsz' 144, 'SOFT' 100, 'WONK' 1;
  }

  .hero-title em {
    font-style: italic;
    color: var(--accent);
    font-variation-settings: 'opsz' 144, 'SOFT' 100, 'WONK' 1;
    background: linear-gradient(180deg, var(--tile-cream), var(--tile-amber));
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    color: transparent;
  }

  .hero-sub {
    font-size: var(--fs-lg);
    max-width: 50ch;
    margin-inline: auto;
    color: var(--text-secondary);
  }

  .hero-sub a {
    color: var(--text-secondary);
    text-decoration: underline;
    text-decoration-color: var(--accent);
    text-decoration-thickness: 1.5px;
    text-underline-offset: 4px;
  }

  .hero-sub a:hover {
    color: var(--accent-hover);
  }

  .hero-ctas {
    display: flex;
    gap: var(--sp-3);
    flex-wrap: wrap;
    justify-content: center;
    margin-top: var(--sp-3);
  }

  .hero-meta {
    color: var(--text-tertiary);
    font-size: var(--fs-xs);
    letter-spacing: 0.04em;
    margin-top: var(--sp-3);
  }
</style>
