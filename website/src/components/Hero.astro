---
import BrandLogo from './BrandLogo.astro';
import { repoUrl, blanketUrl } from '../data/site.ts';
---

<section class="hero" aria-labelledby="hero-heading">
  <div class="container hero-stack">
    <div class="hero-mark" aria-hidden="true">
      <BrandLogo size={96} />
    </div>

    <span class="eyebrow">Ambient sound mixer · Windows</span>

    <h1 id="hero-heading" class="fluent-display hero-title">
      Mix ambient sounds
    </h1>

    <p class="fluent-subtitle1 hero-sub">
      Improve focus, ease into sleep, or set the mood. Fourteen layered soundscapes, native to Windows. A port of <a href={blanketUrl} rel="noopener" target="_blank">Blanket</a>.
    </p>

    <div class="hero-ctas">
      <a href="#download" class="btn btn-primary btn-large">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="16" height="16" aria-hidden="true">
          <path d="M12 17V3 M6 11l6 6 6-6 M19 21H5"></path>
        </svg>
        Download for Windows
      </a>
      <a href={repoUrl} class="btn btn-secondary btn-large" target="_blank" rel="noopener">
        <svg viewBox="0 0 24 24" fill="currentColor" width="16" height="16" aria-hidden="true">
          <path
            d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.1.79-.25.79-.56v-2.16c-3.2.7-3.87-1.37-3.87-1.37-.52-1.32-1.27-1.67-1.27-1.67-1.04-.71.08-.7.08-.7 1.15.08 1.76 1.18 1.76 1.18 1.02 1.75 2.69 1.25 3.34.95.1-.74.4-1.25.73-1.54-2.55-.29-5.24-1.27-5.24-5.65 0-1.25.45-2.27 1.18-3.07-.12-.29-.51-1.46.11-3.04 0 0 .96-.31 3.16 1.17.92-.26 1.9-.39 2.88-.39s1.96.13 2.88.39c2.2-1.48 3.16-1.17 3.16-1.17.62 1.58.23 2.75.11 3.04.74.8 1.18 1.82 1.18 3.07 0 4.39-2.69 5.36-5.25 5.65.41.36.78 1.06.78 2.13v3.16c0 .31.21.67.79.56C20.21 21.39 23.5 17.08 23.5 12 23.5 5.65 18.35.5 12 .5z"
          ></path>
        </svg>
        View on GitHub
      </a>
    </div>

    <p class="hero-meta fluent-caption1">
      Free · GPLv3 · No telemetry · No account
    </p>
  </div>
</section>

<style>
  .hero {
    position: relative;
    padding-block: clamp(var(--space-4xl), 12vw, 8rem) var(--space-5xl);
  }

  .hero-stack {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--space-l);
  }

  .hero-mark {
    margin-bottom: var(--space-s);
    border-radius: 18px;
    box-shadow: var(--shadow-28);
  }

  .hero-title {
    max-width: 18ch;
    margin-inline: auto;
    color: var(--color-neutral-foreground-1);
  }

  .hero-sub {
    max-width: 56ch;
    margin-inline: auto;
    color: var(--color-neutral-foreground-2);
    font-weight: var(--font-weight-regular);
  }

  .hero-ctas {
    display: flex;
    gap: var(--space-m);
    flex-wrap: wrap;
    justify-content: center;
    margin-top: var(--space-s);
  }

  .hero-meta {
    color: var(--color-neutral-foreground-3);
    margin-top: var(--space-s);
  }

  /*
   * Single decelerate-max entrance per Fluent motion guidance, quick fade-up
   * on initial load, no perpetual decoration. 50ms stagger so it reads as one
   * block, not a procession.
   */
  .hero-stack > * {
    opacity: 0;
    transform: translateY(8px);
    animation: hero-rise var(--duration-slow) var(--curve-decelerate-max) forwards;
  }
  .hero-mark   { animation-delay: 0ms; }
  .eyebrow     { animation-delay: 50ms; }
  .hero-title  { animation-delay: 100ms; }
  .hero-sub    { animation-delay: 150ms; }
  .hero-ctas   { animation-delay: 200ms; }
  .hero-meta   { animation-delay: 250ms; }

  @keyframes hero-rise {
    to { opacity: 1; transform: translateY(0); }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-stack > * {
      opacity: 1;
      transform: none;
      animation: none;
    }
  }

  /* Smaller display on phone */
  @media (max-width: 600px) {
    .hero-title { font-size: 40px; line-height: 48px; }
  }
</style>
